---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <div class="relative z-10 flex items-center justify-center h-screen">
      <div class="bg-sky-800 backdrop-blur-md p-10 rounded-2xl shadow-xl w-100">
        <h1 class="text-white text-3xl font-bold text-center mb-6">
          Formulario
        </h1>

        <form class="flex flex-col gap-5" id="formUser">
          <div>
            <label class="text-white block mb-1">Nombre</label>
            <input
              type="text"
              name="name"
              placeholder="Ingresa tu nombre"
              class="w-full px-4 py-2 rounded-lg bg-gray-800 text-white outline-none focus:ring-2 focus:ring-cyan-400"
            />
          </div>

          <div>
            <label class="text-white block mb-1">Nickname</label>
            <input
              type="text"
              name="nickname"
              placeholder="Tu nickname"
              class="w-full px-4 py-2 rounded-lg bg-gray-800 text-white outline-none focus:ring-2 focus:ring-cyan-400"
            />
          </div>

          <button
            type="submit"
            class="mt-4 text-center bg-cyan-500 hover:bg-cyan-400 text-black font-bold py-2 rounded-lg transition"
          >
            Guardar
          </button>
          <a
            href="/"
            class="mt-4 bg-cyan-500 hover:bg-red-500 text-center text-black hover:text-white font-bold py-2 rounded-lg transition"
          >
            Cancelar
          </a>
        </form>
      </div>
    </div>
  </body>
</html>

<script
  src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"
></script>

<script>
  declare global {
    interface Window {
      tsParticles: any;
    }
  }
</script>

<script>
  window.addEventListener("load", () => {
    window.tsParticles.load("tsparticles", {
      fullScreen: { enable: true, zIndex: -1 },

      background: {
        color: "#0d0d0d",
      },

      particles: {
        number: { value: 60 },

        color: { value: "#00ffff" },

        opacity: {
          value: 0.6,
          random: true,
        },

        size: {
          value: { min: 1, max: 3 },
        },

        move: {
          enable: true,
          speed: 1,
        },

        links: {
          enable: true,
          color: "#00ffff",
          distance: 150,
          opacity: 0.4,
          width: 1,
        },

        shadow: {
          enable: true,
          color: "#00ffff",
          blur: 10,
        },
      },

      interactivity: {
        events: {
          onHover: {
            enable: true,
            mode: "grab",
          },
        },
        modes: {
          grab: {
            distance: 200,
            links: {
              opacity: 1,
            },
          },
        },
      },
    });
  });
</script>

<script type="module">
import PouchDB from "https://cdn.jsdelivr.net/npm/pouchdb-browser@8.0.1/+esm";

  const db = new PouchDB("usuarios");

  const form = document.getElementById("formUser");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const data = new FormData(form);

    const user = {
      _id: new Date().toISOString(),
      name: String(data.get("name")),
      nickname: String(data.get("nickname")),
      score:  0,
    };

    try {
      await db.put(user);

      alert("Guardado localmente ✅");

      // redirigir después de guardar
      window.location.href = "/game";
    } catch (error) {
      console.error("Error:", error);
    }
  });
</script>
